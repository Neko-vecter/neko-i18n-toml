{
    "publisher": "Neko-vecter",
    "repository": {
        "type": "git",
        "url": "https://github.com/Neko-vecter/neko-i18n-toml"
    },
    "name": "meow-i18n-toml",
    "displayName": "meow-i18n-toml",
    "icon": "resources/meow-i18n-logo.png",
    "description": "Language support for i18n.toml",
    "version": "1.0.1",
    "engines": {
        "vscode": "^1.118.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "toml",
                "aliases": [
                    "toml",
                    "i18n.toml"
                ],
                "extensions": [
                    ".toml",
                    ".i18n.toml"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "toml",
                "scopeName": "source.toml",
                "path": "./syntaxes/i18n-toml.tmLanguage.json"
            }
        ],
        "configurationDefaults": {
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    {
                        "scope": "source.i18n-toml.color.key",
                        "settings": {
                            "foreground": "#FF5555"
                        }
                    },
                    {
                        "scope": "source.i18n-toml.color.key.sha",
                        "settings": {
                            "foreground": "#fca903"
                        }
                    },
                    {
                        "scope": "source.i18n-toml.color.origin",
                        "settings": {
                            "foreground": "#03fcd7"
                        }
                    },
                    {
                        "scope": "source.i18n-toml.color.origin.val",
                        "settings": {
                            "foreground": "#039dfc"
                        }
                    },
                    {
                        "scope": "source.i18n-toml.color.translate",
                        "settings": {
                            "foreground": "#fc6203"
                        }
                    },
                    {
                        "scope": "source.i18n-toml.color.translate.val",
                        "settings": {
                            "foreground": "#03fc7f"
                        }
                    }
                ]
            }
        }
    },
    "devDependencies": {
        "@vscode/vsce": "^3.9.1"
    }
}
